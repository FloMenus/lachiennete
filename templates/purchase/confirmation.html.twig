{% extends 'base.html.twig' %}

{% block title %}LA_CHIENNETÉ — Commande confirmée{% endblock %}

{% block body %}
    <section class="mx-auto max-w-3xl px-8 pb-24 pt-14">
        <div class="border border-acid bg-void-card p-8">
            <p class="mb-2 text-[10px] uppercase tracking-[0.3em] text-acid-dim">Transaction terminée</p>
            <h1 class="glitch-text -rotate-1 font-display text-[clamp(1.8rem,4vw,2.6rem)] text-acid" data-text="COMMANDE CONFIRMÉE" data-terminal-target="glitch">COMMANDE CONFIRMÉE</h1>
            <p class="mt-3 text-sm text-ink-dim">Référence <span class="font-mono text-acid">CMD_{{ '%05d'|format(purchase.id) }}</span> — passée le {{ purchase.purchasedAt|date('d/m/Y à H:i') }}. Un email de confirmation vous a été envoyé. Ne le montrez à personne.</p>

            <dl class="mt-8 flex flex-col gap-3 border-t border-line pt-6 text-sm">
                <div class="flex justify-between gap-6">
                    <dt class="shrink-0 text-[10px] uppercase tracking-[0.2em] text-ink-dim">Article</dt>
                    <dd class="text-right text-ink">
                        {% if purchase.article %}
                            <a href="{{ path('app_article_show', { id: purchase.article.id }) }}" class="hover:text-acid">{{ purchase.articleTitle }}</a>
                        {% else %}
                            {{ purchase.articleTitle }}
                        {% endif %}
                    </dd>
                </div>
                <div class="flex justify-between gap-6">
                    <dt class="shrink-0 text-[10px] uppercase tracking-[0.2em] text-ink-dim">Montant</dt>
                    <dd class="font-display text-xl text-acid">{{ purchase.price ? purchase.price|number_format(2, ',', ' ') ~ ' €' : '—' }}</dd>
                </div>
                <div class="flex justify-between gap-6">
                    <dt class="shrink-0 text-[10px] uppercase tracking-[0.2em] text-ink-dim">Livraison</dt>
                    <dd class="text-right text-ink-dim">{{ purchase.deliveryAddress }}</dd>
                </div>
                <div class="flex justify-between gap-6">
                    <dt class="shrink-0 text-[10px] uppercase tracking-[0.2em] text-ink-dim">Règlement</dt>
                    <dd class="text-right text-ink-dim">{{ purchase.paymentNote }}</dd>
                </div>
            </dl>

            <p class="mt-6 w-fit -rotate-1 border border-dashed border-amber px-2 py-1 text-[10px] uppercase tracking-widest text-amber">Démonstration — aucun paiement réel, aucun colis, aucun regret</p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                <a href="{{ path('app_purchases') }}" class="flex-1 border border-acid px-4 py-3 text-center text-[12px] font-bold uppercase tracking-wider text-acid transition hover:bg-acid hover:text-void">Voir mes achats</a>
                <a href="{{ path('app_home') }}" class="flex-1 border border-violet px-4 py-3 text-center text-[12px] font-bold uppercase tracking-wider text-violet transition hover:bg-violet hover:text-void">Continuer les emplettes</a>
            </div>
        </div>
    </section>
{% endblock %}
