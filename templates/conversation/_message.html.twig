{# Expects: message (App\Entity\Message) #}
<div id="message_{{ message.id }}" data-author="{{ message.author.id }}" class="max-w-[80%] border border-line bg-void-card px-4 py-3">
    <div class="mb-1 flex items-baseline justify-between gap-6">
        <span class="text-[10px] uppercase tracking-widest text-ink-faint">Agent_{{ message.author.id }}{{ message.author.lastname|slice(0, 1)|upper }}</span>
        <time datetime="{{ message.sentAt|date('c') }}" class="text-[9px] uppercase tracking-wide text-ink-faint">{{ message.sentAt|date('d/m/Y H:i') }}</time>
    </div>
    <p class="whitespace-pre-line text-sm leading-relaxed text-ink">{{ message.content }}</p>
</div>
