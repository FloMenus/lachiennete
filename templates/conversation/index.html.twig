{% extends 'base.html.twig' %}

{% block title %}LA_CHIENNETÉ — Mes conversations{% endblock %}

{% block body %}
    <section class="mx-auto max-w-4xl px-8 pb-24 pt-14">
        <div class="mb-10">
            <h1 class="glitch-text -rotate-1 font-display text-[clamp(1.6rem,3.5vw,2.6rem)] text-ink" data-text="// CANAUX OUVERTS" data-terminal-target="glitch">// CANAUX OUVERTS</h1>
            <p class="mt-2 text-[11px] uppercase tracking-widest text-ink-faint">{{ conversations|length }} conversation{{ conversations|length > 1 ? 's' }} — tout est archivé, rien n'est oublié</p>
        </div>

        {% if conversations|length > 0 %}
            <div class="flex flex-col gap-4">
                {% for conversation in conversations %}
                    {% set article = conversation.article %}
                    {% set other = conversation.buyer.id == app.user.id ? article.seller : conversation.buyer %}
                    {% set lastMessage = conversation.messages|last %}
                    {% set unread = unreadCounts[conversation.id]|default(0) %}
                    <a href="{{ path('app_conversation_show', { id: conversation.id }) }}"
                       class="group flex items-center gap-5 border border-line bg-void-card p-4 transition hover:-translate-y-0.5 hover:border-acid-dim {{ cycle(['rotate-0', '-rotate-[0.3deg]', 'rotate-[0.3deg]'], loop.index0) }}">
                        {% set mainImage = article.images.first %}
                        <div class="h-16 w-16 shrink-0 overflow-hidden border border-line bg-void-raised">
                            {% if mainImage %}
                                <img src="{{ asset('uploads/articles/' ~ mainImage.filename) }}" alt="{{ mainImage.alt|default(article.title) }}" loading="lazy" class="h-full w-full object-cover grayscale-[50%] transition group-hover:grayscale-0">
                            {% else %}
                                <div class="flex h-full items-center justify-center text-[9px] text-ink-faint">N/A</div>
                            {% endif %}
                        </div>

                        <div class="min-w-0 flex-1">
                            <div class="flex items-baseline justify-between gap-4">
                                <span class="truncate text-sm text-ink group-hover:text-acid">{{ article.title }}</span>
                                {% if lastMessage %}
                                    <time datetime="{{ lastMessage.sentAt|date('c') }}" class="shrink-0 text-[9px] uppercase tracking-wide text-ink-faint">{{ lastMessage.sentAt|date('d/m/Y H:i') }}</time>
                                {% endif %}
                            </div>
                            <p class="mt-0.5 text-[10px] uppercase tracking-widest text-ink-faint">
                                Avec <span class="text-violet">Agent_{{ other.id }}{{ other.lastname|slice(0, 1)|upper }}</span>
                                {{ other.id == article.seller.id ? '(vendeur)' : '(acheteur)' }}
                            </p>
                            <p class="mt-1.5 truncate text-[13px] text-ink-dim">
                                {% if lastMessage %}
                                    {% if lastMessage.author.id == app.user.id %}<span class="text-ink-faint">Vous :</span>{% endif %}
                                    {{ lastMessage.content }}
                                {% else %}
                                    <span class="italic text-ink-faint">Canal ouvert, aucun message.</span>
                                {% endif %}
                            </p>
                        </div>

                        {% if unread > 0 %}
                            <span class="shrink-0 -rotate-3 bg-blood px-2 py-1 text-[10px] font-bold uppercase tracking-wider text-void">{{ unread }} non lu{{ unread > 1 ? 's' }}</span>
                        {% endif %}
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="border border-dashed border-line p-10 text-center">
                <p class="italic text-ink-faint">Aucune conversation. Personne ne veut vous parler, ou vous n'avez encore rien acheté de compromettant.</p>
                <a href="{{ path('app_home') }}#listing" class="mt-4 inline-block border border-violet px-4 py-2 text-[11px] font-bold uppercase tracking-wider text-violet transition hover:bg-violet hover:text-void">Parcourir les annonces</a>
            </div>
        {% endif %}
    </section>
{% endblock %}
