<header class="sticky top-0 z-50 flex flex-wrap items-center justify-between gap-6 border-b border-line bg-gradient-to-b from-void-raised to-void px-8 py-4">
    <a href="{{ path('app_home') }}" class="flex items-baseline gap-3">
        <span class="glitch-text -skew-x-6 font-display text-2xl font-bold text-acid" data-text="LA_CHIENNETÉ" data-terminal-target="glitch">LA_CHIENNETÉ</span>
        <span class="-rotate-2 border border-dashed border-ink-faint px-1.5 py-0.5 text-[10px] text-ink-dim">BUILD 0.6.6</span>
    </a>

    <nav class="flex gap-7 text-xs uppercase tracking-widest" aria-label="Navigation principale">
        <a href="{{ path('app_home') }}" class="hover:text-blood">Accueil</a>
        {% if app.user %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin') }}" class="text-blood hover:text-ink">Admin</a>
            {% endif %}
            {% if is_granted('ROLE_PRESTATAIRE') and not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_seller_articles') }}" class="text-amber hover:text-blood">Mes annonces</a>
            {% endif %}
            {% if is_granted('ROLE_CLIENT') %}
                <a href="{{ path('app_favorites') }}" class="hover:text-blood">♥ Favoris</a>
            {% endif %}
            <a href="{{ path('app_conversations') }}" class="hover:text-blood">✉ Messages</a>
            <a href="{{ path('app_profile') }}" class="translate-y-0.5 text-acid hover:text-blood">Mon dossier</a>
            <a href="{{ path('app_logout') }}" class="text-ink-faint hover:text-blood">Déconnexion</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="translate-y-0.5 text-ink-faint hover:text-blood">Connexion</a>
        {% endif %}
    </nav>

    <div class="flex items-center gap-0.5 text-xs text-ink-dim">
        <span class="text-violet">{{ app.user ? ('agent_' ~ app.user.id ~ app.user.lastname|slice(0, 1)|lower) : 'guest' }}@onion</span><span>:</span><span>~$</span>
        <span class="ml-2 text-acid" data-terminal-target="clock">00:00:00</span>
        <span class="ml-0.5 animate-[blink_1s_steps(1)_infinite] text-acid" aria-hidden="true">▌</span>
    </div>
</header>
