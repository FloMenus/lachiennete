{% extends 'base.html.twig' %}

{% block title %}LA_CHIENNETÉ — Mes annonces{% endblock %}

{% block body %}
    <section class="mx-auto max-w-5xl px-8 pb-24 pt-14">
        <p class="mb-4 text-[11px] uppercase tracking-[0.25em] text-violet">[ ESPACE PRESTATAIRE // GESTION DES ACTIFS ]</p>
        <div class="flex items-end justify-between">
            <h1 class="font-display text-[clamp(2rem,5vw,4rem)] leading-tight text-ink">MES ANNONCES</h1>
            <a href="{{ path('app_seller_article_new') }}"
                class="border border-acid px-4 py-2.5 text-[11px] font-bold uppercase tracking-wider text-acid transition hover:bg-acid hover:text-void">
                + Nouvelle annonce
            </a>
        </div>

        <div class="mt-10 flex flex-col gap-3">
            {% for article in articles %}
                <div class="flex items-center justify-between gap-6 border border-line bg-void-card px-5 py-4">
                    <div class="min-w-0 flex-1">
                        <a href="{{ path('app_article_show', { id: article.id }) }}" class="font-display text-base text-ink hover:text-acid">
                            {{ article.title }}
                        </a>
                        <p class="mt-0.5 text-[11px] text-ink-faint">
                            {% if article.category %}<span class="text-violet">{{ article.category.name }}</span> — {% endif %}
                            {{ article.images|length }} image{{ article.images|length > 1 ? 's' : '' }}
                            — {{ article.createdAt|date('d/m/Y') }}
                        </p>
                    </div>

                    <div class="flex shrink-0 items-center gap-3">
                        {% if article.price %}
                            <span class="text-sm text-acid">{{ article.price|number_format(2, ',', ' ') }} €</span>
                        {% else %}
                            <span class="text-[11px] text-blood">DEVIS</span>
                        {% endif %}

                        <a href="{{ path('app_seller_article_edit', { id: article.id }) }}"
                            class="border border-violet px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-violet transition hover:bg-violet hover:text-void">
                            Modifier
                        </a>

                        <form method="post" action="{{ path('app_seller_article_delete', { id: article.id }) }}"
                            onsubmit="return confirm('Supprimer « {{ article.title|e('js') }} » ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ article.id) }}">
                            <button type="submit"
                                class="border border-blood px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-blood transition hover:bg-blood hover:text-void">
                                Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="border border-line bg-void-card px-6 py-10 text-center">
                    <p class="text-sm italic text-ink-faint">Aucune annonce publiée.</p>
                    <a href="{{ path('app_seller_article_new') }}" class="mt-4 inline-block border border-acid px-4 py-2 text-[11px] font-bold uppercase tracking-wider text-acid transition hover:bg-acid hover:text-void">
                        Créer la première
                    </a>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
