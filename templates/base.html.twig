<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="robots" content="noindex, nofollow">
        <meta name="color-scheme" content="dark">
        <title>{% block title %}LA_CHIENNETÉ — tout s'achète{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🕳️</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/custom.css') }}">
            <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
            <style type="text/tailwindcss">
                @theme {
                    --color-void: #060608;
                    --color-void-raised: #0d0d11;
                    --color-void-card: #101014;
                    --color-line: #232329;
                    --color-acid: #39ff8c;
                    --color-acid-dim: #1f8f52;
                    --color-blood: #ff1f4b;
                    --color-violet: #9b5cff;
                    --color-amber: #ffb020;
                    --color-ink: #d8d8dd;
                    --color-ink-dim: #726f7d;
                    --color-ink-faint: #45424e;
                    --font-mono: ui-monospace, 'SFMono-Regular', Menlo, Consolas, 'Courier New', monospace;
                    --font-display: Georgia, 'Times New Roman', serif;
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="relative min-h-screen overflow-x-hidden bg-void font-mono text-[15px] leading-relaxed text-ink cursor-crosshair" data-controller="terminal">
        <div class="noise-layer" aria-hidden="true"></div>
        <div class="scanline-layer" aria-hidden="true"></div>

        <div class="overflow-hidden whitespace-nowrap border-b-2 border-void bg-blood text-[11px] font-bold tracking-wider text-void" role="presentation" aria-hidden="true">
            <div class="inline-flex animate-[ticker-scroll_38s_linear_infinite]">
                {% for i in 1..2 %}
                <span class="py-1 pr-8">⚠ CE SITE EST UNE DÉMONSTRATION — AUCUN BIEN N'EST RÉEL — ⚠ CONNEXION NON CHIFFRÉE DÉTECTÉE — ⚠ NE FAITES CONFIANCE À PERSONNE, SURTOUT PAS À CE BANDEAU — ⚠ 17 AGENTS ACTUELLEMENT CONNECTÉS — ⚠ LES AVIS 5 ÉTOILES SONT SUSPECTS — ⚠</span>
                {% endfor %}
            </div>
        </div>

        {% include 'partials/_navbar.html.twig' %}

        <main>
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mx-auto mt-6 max-w-6xl border-l-4 {{ label == 'error' ? 'border-blood' : 'border-acid' }} bg-void-raised px-5 py-3 text-sm">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% include 'partials/_footer.html.twig' %}
    </body>
</html>
